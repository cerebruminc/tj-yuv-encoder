{
  "name": "@cerebruminc/i420-jpeg-encoder",
  "version": "1.0.1",
  "description": "Node.js native I420 to JPEG encoder backed by libjpeg-turbo.",
  "main": "dist/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:native && npm run build:ts",
    "build:native": "npm run check:native-deps && node-gyp rebuild",
    "build:ts": "tsc -p tsconfig.json",
    "check:native-deps": "node scripts/check-native-deps.js",
    "clean": "node-gyp clean && rm -rf dist",
    "install": "node scripts/check-native-deps.js && node-gyp rebuild",
    "prepack": "npm run build",
    "prepare": "npm run build:ts",
    "pretest": "npm run build",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cerebruminc/i420-jpeg-encoder.git"
  },
  "keywords": [
    "jpeg",
    "turbojpeg",
    "i420",
    "yuv420",
    "napi"
  ],
  "author": "Cerebrum LLC",
  "license": "GPL-3.0-only",
  "type": "commonjs",
  "files": [
    "binding.gyp",
    "dist",
    "index.d.ts",
    "scripts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0"
  },
  "gypfile": true,
  "bugs": {
    "url": "https://github.com/cerebruminc/i420-jpeg-encoder/issues"
  },
  "homepage": "https://github.com/cerebruminc/i420-jpeg-encoder#readme",
  "devDependencies": {
    "@types/node": "^20.19.39",
    "jest": "^30.3.0",
    "jpeg-js": "^0.4.4",
    "node-gyp": "^12.3.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "node-addon-api": "^8.7.0"
  }
}
